# ============================
# Telegram Bot Configuration
# ============================

# Токен бота від @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Username бота (без @)
BOT_USERNAME=YourTicketBot

# URL для webhook (публічний HTTPS URL, де буде доступний FastAPI)
WEBHOOK_URL=https://your-domain.com

# Шлях webhook (зазвичай не змінювати)
WEBHOOK_PATH=/webhook

# ============================
# Database Configuration
# ============================

# DSN для підключення до MySQL (asyncio driver)
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/ticketbot

# Для dev може бути true. Для production встановіть false і запускайте alembic upgrade head.
DATABASE_AUTO_CREATE_TABLES=true

# ============================
# Security
# ============================

# Секретний ключ для підписання токенів (згенеруйте випадковий рядок 32+ символів)
SECRET_KEY=your-super-secret-key-change-this-in-production

# ============================
# Payments
# ============================

# Telegram payment provider token. Якщо порожній, бот використовує тестову оплату callback-кнопкою.
PAYMENT_PROVIDER_TOKEN=

# Валюта Telegram Payments
PAYMENT_CURRENCY=UAH

# ============================
# Admin Configuration
# ============================

# Telegram ID адміністраторів (через кому)
ADMIN_IDS=123456789,987654321

# ============================
# Application Settings
# ============================

# Хост та порт для запуску FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000

# Режим налагодження
DEBUG=true

# Дозволені origins для browser-запитів Mini App/API (через кому)
CORS_ORIGINS=https://your-domain.com

# Час блокування місця (в секундах, за замовчуванням 10 хвилин)
SEAT_LOCK_TIMEOUT=600

# Час очікування підтвердження квитка (в секундах, за замовчуванням 2 хвилини)
VERIFICATION_TIMEOUT=120
